@model IEnumerable<TechCorePayroll.Models.Employee>

@{
    ViewData["Title"] = "Payroll";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="badge-soft">Payroll Access</span>
        <h1 class="h3 mb-1">Payroll</h1>
        <div class="text-muted">Select an employee to view payroll history.</div>
    </div>
    <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-secondary">Manage Employees</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Employee</th>
            <th>Position</th>
            <th>Department</th>
            <th>Daily Rate</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-muted">No employees found.</td>
            </tr>
        }
        else
        {
            @foreach (var employee in Model)
            {
                <tr>
                    <td>@employee.FullName</td>
                    <td>@employee.Position</td>
                    <td>@employee.Department</td>
                    <td>@employee.DailyRate.ToString("C")</td>
                    <td class="text-end">
                        <a asp-action="Index" asp-route-employeeId="@employee.EmployeeId" class="btn btn-sm btn-outline-primary">View Payroll</a>
                        <a asp-action="Create" asp-route-employeeId="@employee.EmployeeId" class="btn btn-sm btn-outline-secondary">Add Payroll</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
