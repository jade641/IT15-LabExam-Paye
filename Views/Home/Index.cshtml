@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-5">
    <span class="badge-soft">HR Command Center</span>
    <h1 class="display-5 mt-3">TechCore Solutions HR</h1>
    <p class="lead text-muted">Track employee details, daily rates, and payroll history with precision.</p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Employees</h2>
                <p class="text-muted">Maintain employee profiles, roles, and departmental assignments.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-primary">Manage Employees</a>
                    <a asp-controller="Employee" asp-action="Create" class="btn btn-outline-secondary">Add New</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h4">Payroll</h2>
                <p class="text-muted">Review payroll history, track deductions, and keep computations transparent.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Payroll" asp-action="Index" class="btn btn-primary">View Payroll</a>
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-secondary">Select Employee</a>
                </div>
            </div>
        </div>
    </div>
</div>
